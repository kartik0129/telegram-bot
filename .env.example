# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Render domain (set automatically by Render, or use for local webhook testing)
RENDER_EXTERNAL_URL=https://your-app.onrender.com

# Local development (leave blank to use polling mode)
PORT=3000

# Your Telegram user/chat ID (for automated daily briefing delivery)
# Message @userinfobot on Telegram to get your ID
CHAT_ID=
